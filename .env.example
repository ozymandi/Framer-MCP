# SINGLE-PROJECT MODE (default).
FRAMER_API_KEY=
FRAMER_PROJECT_URL=https://framer.com/projects/Your-Project--aabbccdd1122

# MULTI-PROJECT MODE (optional). When set, FRAMER_API_KEY + FRAMER_PROJECT_URL
# above are ignored. The file is a JSON array:
#   [
#     { "alias": "portfolio", "url": "https://framer.com/projects/...", "apiKey": "fr_..." },
#     { "alias": "blog",      "url": "https://framer.com/projects/...", "apiKey": "fr_..." }
#   ]
# FRAMER_PROJECTS_FILE=./projects.json

MCP_AUTH_TOKEN=change-me
MCP_PORT=3000

# Hard ceiling for a single asset payload, in bytes. Defaults to 50 MiB.
# MAX_ASSET_BYTES=52428800
